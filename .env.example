# ─────────────────────────────────────────────────────────────────────────
#  .env.example — 실제 .env 파일을 이 형식으로 작성하세요.
#  ※ .env 는 절대 Git 에 커밋하지 마세요 (.gitignore 로 차단됨).
#  ※ 환경 변수는 config.py 가 시작 시점에 1회만 로드합니다 (load_dotenv).
# ─────────────────────────────────────────────────────────────────────────

# =========================================================================
# 1) 키움 REST 자격증명 (필수, 실전투자 전용)
#    Open API 키는 키움증권 OpenAPI 신청 페이지에서 발급
#    → https://openapi.kiwoom.com → 앱 등록 → AppKey / SecretKey
# =========================================================================
KIWOOM_ACCOUNT_NO=00000000-00          # 종합계좌번호 (예: 5581-5936) — kt00018, 주문 라우팅용
KIWOOM_APPKEY=your_kiwoom_appkey
KIWOOM_SECRETKEY=your_kiwoom_secretkey

# =========================================================================
# 2) AI 판단 엔진 (선택)
#    Gemini 2.5 Flash Lite 모델로 스크리너 종목별 AI 신뢰도를 계산합니다.
#    키 미설정 시 — Tech + Fund 점수만 사용 (AI 부분은 0으로 처리).
# =========================================================================
GEMINI_API_KEY=your_gemini_api_key

# =========================================================================
# 3) 해외 시세 폴백 (선택)
#    Finnhub.io 무료 티어 (분당 60호출) — yfinance 가 막힌 티커를 대체.
#    키 미설정 시 — yfinance 만 사용.
# =========================================================================
FINNHUB_API_KEY=your_finnhub_api_key

# =========================================================================
# 4) 텔레그램 알림 (선택, 그러나 운영 시 강력히 권장)
#    Bot 생성: @BotFather → /newbot → 토큰 발급
#    chat_id 확인: 봇과 대화 후 https://api.telegram.org/bot<token>/getUpdates
# =========================================================================
TELEGRAM_BOT_TOKEN=1234567890:ABC...
TELEGRAM_CHAT_ID=123456789

# =========================================================================
# 5) 대시보드 비밀번호 (admin / client 분리)
#    /advanced 는 admin 만 — 잔고/주문/설정 모두 노출.
#    /client 는 비번 없이 접근 (보유 종목·평가/청산 손익만, 민감정보 비공개).
#    DASHBOARD_CLIENT_PASSWORD 가 비어 있으면 기존 client 로그인 흐름은 비활성화됩니다.
# =========================================================================
DASHBOARD_ADMIN_PASSWORD=긴_랜덤_관리자비번_여기에
DASHBOARD_CLIENT_PASSWORD=                       # 친구 공유용 client 로그인 (옵션)
# 하위 호환 — 옛 코드가 DASHBOARD_PASSWORD 만 읽는 경우. 위의 ADMIN 만 설정하면 됩니다.
# DASHBOARD_PASSWORD=

# =========================================================================
# 6) Flask 세션 키 (선택, 미설정 시 매 재시작마다 secrets.token_hex(32) 자동 발급)
#    프로세스 재시작 후에도 로그인 세션을 유지하려면 고정 값을 두세요.
# =========================================================================
DASHBOARD_SECRET_KEY=                            # 64자 이상 hex 문자열 권장 (예: openssl rand -hex 32)

# =========================================================================
# 참고 — 운영 모드 (별도 환경변수 없음)
#   ※ 본 시스템은 실전투자 전용입니다. 모의/페이퍼 모드는 제거되었습니다.
#   ※ 리스크 파라미터는 config.py RISK_CONFIG 에서, 감시 종목 등 런타임 옵션은
#     user_config.json 에서 관리합니다 (.env 가 아님).
# =========================================================================
