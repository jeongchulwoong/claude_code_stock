# ─────────────────────────────────────────────
# .env.example — 실제 .env 파일을 이 형식으로 작성하세요
# .env 파일은 절대 Git에 커밋하지 마세요!
# ─────────────────────────────────────────────

# 키움증권 계좌 (모의투자 / 실계좌)
KIWOOM_ACCOUNT_NO=1234567890

# Claude API Key (AI 판단 엔진)
ANTHROPIC_API_KEY=sk-ant-...

# 텔레그램 알림
TELEGRAM_BOT_TOKEN=1234567890:ABC...
TELEGRAM_CHAT_ID=123456789

# 운영 모드: paper | live
TRADING_MODE=paper
